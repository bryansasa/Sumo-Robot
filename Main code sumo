const char* stateName(RobotState s) {
  switch (s) {
    case STATE_SEARCH:      return "SEARCH";
    case STATE_TRACK_LEFT:  return "TRACK_LEFT";
    case STATE_TRACK_RIGHT: return "TRACK_RIGHT";
    case STATE_ATTACK:      return "ATTACK";
    case STATE_PUSH:        return "PUSH";
    case STATE_AVOID_LINE:  return "AVOID_LINE";
    case STATE_ANTI_STUCK:  return "ANTI_STUCK";
    default:                return "UNKNOWN";
  }
}

const char* targetName(TargetDir t) {
  switch (t) {
    case TARGET_NONE:  return "NONE";
    case TARGET_FRONT: return "FRONT";
    case TARGET_LEFT:  return "LEFT";
    case TARGET_RIGHT: return "RIGHT";
    case TARGET_CLOSE: return "CLOSE";
    default:           return "UNKNOWN";
  }
}

void setState(RobotState newState) {
  RobotState oldState = robotState;

  if (oldState != newState) {
    robotState = newState;
    stateEnterMs = millis();

    Serial.print("STATE: ");
    Serial.print(stateName(oldState));
    Serial.print(" -> ");
    Serial.println(stateName(newState));
  }
}

// ======================================================
// IR LINE READING
// ======================================================
uint8_t readLineCodeNow() {
  bool kiriDepan = digitalRead(IR_KIRI_DEPAN) == GARIS_TERDETEKSI;
  bool kananDepan = digitalRead(IR_KANAN_DEPAN) == GARIS_TERDETEKSI;
  bool kiriBelakang = digitalRead(IR_KIRI_BELAKANG) == GARIS_TERDETEKSI;
  bool kananBelakang = digitalRead(IR_KANAN_BELAKANG) == GARIS_TERDETEKSI;

  // Prioritas depan dulu, karena paling berbahaya saat robot menyerang
  if (kiriDepan && kananDepan) {
    return LINE_FRONT_BOTH;
  }

  if (kiriDepan) {
    return LINE_FRONT_LEFT;
  }

  if (kananDepan) {
    return LINE_FRONT_RIGHT;
  }

  if (kiriBelakang && kananBelakang) {
    return LINE_BACK_BOTH;
  }

  if (kiriBelakang) {
    return LINE_BACK_LEFT;
  }

  if (kananBelakang) {
    return LINE_BACK_RIGHT;
  }

  return LINE_NONE;
}

bool lineIsFront(uint8_t code) {
  return code == LINE_FRONT_LEFT ||
         code == LINE_FRONT_RIGHT ||
         code == LINE_FRONT_BOTH;
}

bool lineIsBack(uint8_t code) {
  return code == LINE_BACK_LEFT ||
         code == LINE_BACK_RIGHT ||
         code == LINE_BACK_BOTH;
}

bool lineTurnRight(uint8_t code) {
  if (code == LINE_FRONT_LEFT) return true;
  if (code == LINE_FRONT_RIGHT) return false;
  if (code == LINE_FRONT_BOTH) return true;

  if (code == LINE_BACK_LEFT) return true;
  if (code == LINE_BACK_RIGHT) return false;
  if (code == LINE_BACK_BOTH) return false;

  return true;
}

// ======================================================
// ULTRASONIC
// ======================================================
long readDistanceRaw(int trigPin, int echoPin) {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);

  digitalWrite(trigPin, LOW);

  long duration = pulseIn(echoPin, HIGH, TIMEOUT_ULTRASONIK);

  if (duration == 0) {
    return 999;
  }

  long distance = duration * 0.034 / 2;

  if (distance <= 0 || distance > 200) {
    return 999;
  }

  return distance;
}

bool jarakValid(long jarak) {
  return jarak > 0 && jarak < 999;
}

// ======================================================
// TARGET DECISION - AGGRESSIVE
// ======================================================
TargetDir readTargetRawSmart(long tengah, long kiri, long kanan) {
  bool tengahValid = jarakValid(tengah);
  bool kiriValid = jarakValid(kiri);
  bool kananValid = jarakValid(kanan);

  // 1. Kalau depan sangat dekat, langsung dorong
  if (tengahValid && tengah <= JARAK_SANGAT_DEKAT) {
    return TARGET_CLOSE;
  }

  // 2. Depan adalah prioritas utama.
  // Kalau sensor tengah melihat lawan, langsung serang.
  bool frontOn = tengahValid && tengah <= JARAK_SERANG_DEPAN_ON;

  bool sedangAttack = robotState == STATE_ATTACK ||
                      robotState == STATE_PUSH ||
                      lockedTargetDir == TARGET_FRONT ||
                      lockedTargetDir == TARGET_CLOSE;

  bool frontHold = sedangAttack &&
                   tengahValid &&
                   tengah <= JARAK_SERANG_DEPAN_OFF;

  if (frontOn || frontHold) {
    return TARGET_FRONT;
  }

  // 3. Sensor samping dibuat lebih mudah mengunci target.
  bool kiriOn = false;
  bool kananOn = false;

  if (kiriValid) {
    if (lockedTargetDir == TARGET_LEFT) {
      kiriOn = kiri <= JARAK_TARGET_SAMPING_OFF;
    } else {
      kiriOn = kiri <= JARAK_TARGET_SAMPING_ON;
    }
  }

  if (kananValid) {
    if (lockedTargetDir == TARGET_RIGHT) {
      kananOn = kanan <= JARAK_TARGET_SAMPING_OFF;
    } else {
      kananOn = kanan <= JARAK_TARGET_SAMPING_ON;
    }
  }

  // 4. Kalau sedang lock kiri dan kiri masih masuk batas OFF,
  // jangan gampang pindah kanan.
  if (lockedTargetDir == TARGET_LEFT && kiriOn) {
    if (!kananOn) {
      return TARGET_LEFT;
    }

    if (abs(kiri - kanan) <= TARGET_SIDE_MARGIN_CM) {
      return TARGET_LEFT;
    }
  }

  // 5. Kalau sedang lock kanan dan kanan masih masuk batas OFF,
  // jangan gampang pindah kiri.
  if (lockedTargetDir == TARGET_RIGHT && kananOn) {
    if (!kiriOn) {
      return TARGET_RIGHT;
    }

    if (abs(kiri - kanan) <= TARGET_SIDE_MARGIN_CM) {
      return TARGET_RIGHT;
    }
  }

  // 6. Kalau kiri dan kanan sama-sama melihat,
  // pilih yang lebih dekat.
  if (kiriOn && kananOn) {
    if (kiri <= kanan) {
      return TARGET_LEFT;
    } else {
      return TARGET_RIGHT;
    }
  }

  if (kiriOn) {
    return TARGET_LEFT;
  }

  if (kananOn) {
    return TARGET_RIGHT;
  }

  return TARGET_NONE;
}

TargetDir getDecisionTarget(long tengah, long kiri, long kanan) {
  unsigned long now = millis();

  TargetDir rawTarget = readTargetRawSmart(tengah, kiri, kanan);

  if (rawTarget != TARGET_NONE) {
    lastTargetSeenMs = now;
    lastTargetDir = rawTarget;

    // FRONT dan CLOSE boleh override kapan saja
    if (rawTarget == TARGET_FRONT || rawTarget == TARGET_CLOSE) {
      lockedTargetDir = rawTarget;
      targetLockStartMs = now;
      return rawTarget;
    }

    // Kalau belum ada lock, ambil target baru
    if (lockedTargetDir == TARGET_NONE) {
      lockedTargetDir = rawTarget;
      targetLockStartMs = now;
      return rawTarget;
    }

    // Kalau target sama dengan lock, lanjut
    if (rawTarget == lockedTargetDir) {
      targetLockStartMs = now;
      return lockedTargetDir;
    }

    // Kalau masih masa lock, jangan pindah kiri-kanan dulu
    if (now - targetLockStartMs < TARGET_LOCK_MS) {
      return lockedTargetDir;
    }

    // Lock sudah lewat, boleh pindah target
    lockedTargetDir = rawTarget;
    targetLockStartMs = now;
    return rawTarget;
  }

  // Kalau target hilang sebentar, tetap pakai target terakhir
  if (lastTargetDir != TARGET_NONE && now - lastTargetSeenMs <= TARGET_LOST_MS) {
    return lastTargetDir;
  }

  lockedTargetDir = TARGET_NONE;
  lastTargetDir = TARGET_NONE;

  return TARGET_NONE;
}

// ======================================================
// PID TARGET STEERING
// ======================================================
void resetTargetPID() {
  pidErrorLast = 0;
  pidIntegral = 0;
  pidLastMs = millis();
}

float getTargetError(TargetDir target, long tengah, long kiri, long kanan) {
  bool kiriValid = jarakValid(kiri);
  bool kananValid = jarakValid(kanan);

  // Error negatif = target di kiri
  // Error positif = target di kanan

  if (target == TARGET_LEFT) {
    if (kiriValid) {
      return -1.0 * (JARAK_TARGET_SAMPING_OFF - kiri);
    }

    return -25.0;
  }

  if (target == TARGET_RIGHT) {
    if (kananValid) {
      return 1.0 * (JARAK_TARGET_SAMPING_OFF - kanan);
    }

    return 25.0;
  }

  if (target == TARGET_FRONT || target == TARGET_CLOSE) {
    // Kalau dua sensor samping valid, bantu koreksi arah
    // kiri lebih dekat dari kanan = target agak kiri = error negatif
    if (kiriValid && kananValid) {
      return kiri - kanan;
    }

    if (kiriValid && !kananValid) {
      return -8.0;
    }

    if (!kiriValid && kananValid) {
      return 8.0;
    }

    return 0.0;
  }

  return 0.0;
}

int computePIDCorrection(float error) {
  unsigned long now = millis();

  float dt = (now - pidLastMs) / 1000.0;

  if (dt <= 0.001) {
    dt = 0.001;
  }

  pidIntegral += error * dt;
  pidIntegral = constrain(pidIntegral, -40, 40);

  float derivative = (error - pidErrorLast) / dt;

  float output = (KpTarget * error) +
                 (KiTarget * pidIntegral) +
                 (KdTarget * derivative);

  pidErrorLast = error;
  pidLastMs = now;

  output = constrain(output, -PID_CORRECTION_LIMIT, PID_CORRECTION_LIMIT);

  return (int)output;
}

void motorTrackPID(TargetDir target, long tengah, long kiri, long kanan) {
  float error = getTargetError(target, tengah, kiri, kanan);
  int correction = computePIDCorrection(error);

  int speedKiri = SPEED_TRACK_BASE + correction;
  int speedKanan = SPEED_TRACK_BASE - correction;

  speedKiri = constrain(speedKiri, SPEED_TRACK_MIN, SPEED_TRACK_MAX);
  speedKanan = constrain(speedKanan, SPEED_TRACK_MIN, SPEED_TRACK_MAX);

  motorMajuLR(speedKiri, speedKanan);
}

// ======================================================
// AVOID LINE STATE
// ======================================================
void beginAvoidLine() {
  avoidLineSnapshot = gLineCode;

  if (avoidLineSnapshot == LINE_NONE) {
    avoidLineSnapshot = readLineCodeNow();
  }

  avoidStep = 0;
  stateStepStartMs = millis();

  deadlockStartMs = 0;

  // Reset target supaya setelah koreksi garis, robot cari ulang
  lockedTargetDir = TARGET_NONE;
  lastTargetDir = TARGET_NONE;
  resetTargetPID();

  motorBerhenti();
  setState(STATE_AVOID_LINE);

  Serial.print("LINE CODE: ");
  Serial.println(avoidLineSnapshot);
}

void processAvoidLine() {
  unsigned long now = millis();

  switch (avoidStep) {
    case 0:
      motorBerhenti();

      if (now - stateStepStartMs >= GARIS_STOP_MS) {
        avoidStep = 1;
        stateStepStartMs = now;
      }
      break;

    case 1:
      if (lineIsFront(avoidLineSnapshot)) {
        motorMundur(SPEED_HINDAR);

        if (now - stateStepStartMs >= GARIS_MUNDUR_MS) {
          avoidStep = 2;
          stateStepStartMs = now;
        }
      } else if (lineIsBack(avoidLineSnapshot)) {
        motorMaju(SPEED_HINDAR);

        if (now - stateStepStartMs >= GARIS_MAJU_MS) {
          avoidStep = 2;
          stateStepStartMs = now;
        }
      } else {
        avoidStep = 3;
        stateStepStartMs = now;
      }
      break;

    case 2:
      if (lineTurnRight(avoidLineSnapshot)) {
        motorKanan(SPEED_HINDAR);
      } else {
        motorKiri(SPEED_HINDAR);
      }

      if (lineIsFront(avoidLineSnapshot)) {
        if (now - stateStepStartMs >= GARIS_BELOK_DEPAN_MS) {
          avoidStep = 3;
          stateStepStartMs = now;
        }
      } else {
        if (now - stateStepStartMs >= GARIS_BELOK_BELAKANG_MS) {
          avoidStep = 3;
          stateStepStartMs = now;
        }
      }
      break;

    case 3:
      motorBerhenti();

      if (now - stateStepStartMs >= GARIS_SELESAI_MS) {
        avoidStep = 0;
        setState(STATE_SEARCH);
      }
      break;
  }
}

// ======================================================
// ANTI STUCK STATE
// ======================================================
void beginAntiStuck() {
  antiStuckStep = 0;
  stateStepStartMs = millis();

  // Reset target supaya setelah anti-stuck, robot cari ulang
  lockedTargetDir = TARGET_NONE;
  lastTargetDir = TARGET_NONE;
  resetTargetPID();

  motorBerhenti();
  setState(STATE_ANTI_STUCK);

  Serial.println("ANTI STUCK: mulai mundur dan belok jauh");
}

void processAntiStuck() {
  unsigned long now = millis();

  switch (antiStuckStep) {
    case 0:
      motorBerhenti();

      if (now - stateStepStartMs >= ANTISTUCK_STOP_MS) {
        antiStuckStep = 1;
        stateStepStartMs = now;
      }
      break;

    case 1:
      motorMundur(SPEED_HINDAR);

      if (now - stateStepStartMs >= ANTISTUCK_MUNDUR_MS) {
        antiStuckStep = 2;
        stateStepStartMs = now;
      }
      break;

    case 2:
      if (antiStuckBelokKanan) {
        motorKanan(SPEED_HINDAR);
      } else {
        motorKiri(SPEED_HINDAR);
      }

      if (now - stateStepStartMs >= ANTISTUCK_BELOK_MS) {
        antiStuckStep = 3;
        stateStepStartMs = now;
      }
      break;

    case 3:
      motorBerhenti();

      if (now - stateStepStartMs >= ANTISTUCK_SELESAI_MS) {
        antiStuckBelokKanan = !antiStuckBelokKanan;
        deadlockStartMs = 0;
        antiStuckStep = 0;
        setState(STATE_SEARCH);
      }
      break;
  }
}

// ======================================================
// DEADLOCK CHECK
// ======================================================
bool checkDeadlock(float accelX, long jarakTengah) {
  unsigned long now = millis();

  bool targetDekat = jarakTengah <= JARAK_DEADLOCK;

  bool indikasiTidakBergerak = false;

  if (mpuOK) {
    indikasiTidakBergerak = fabs(accelX) < 1.2;
  } else {
    indikasiTidakBergerak = true;
  }

  if (targetDekat && indikasiTidakBergerak) {
    if (deadlockStartMs == 0) {
      deadlockStartMs = now;
    }

    if (now - deadlockStartMs >= DEADLOCK_MS) {
      beginAntiStuck();
      return true;
    }
  } else {
    deadlockStartMs = 0;
  }

  return false;
}

// ======================================================
// SEARCH MOTION
// ======================================================
void doSearchMotion() {
  // SEARCH sekarang "putar - lirik": putar sebentar, lalu diam sejenak.
  // Saat diam, robot tidak menambah blur pada pembacaan ultrasonik,
  // jadi begitu lawan masuk jarak deteksi, nilai gJarakTengah/Kiri/Kanan
  // yang terbaca benar-benar valid dan langsung dipakai pada loop
  // berikutnya untuk pindah ke ATTACK/PUSH.
  unsigned long now = millis();
  unsigned long elapsed = now - searchSwitchMs;

  if (elapsed < SEARCH_SPIN_MS) {
    motorKanan(SPEED_CARI);
  } else if (elapsed < SEARCH_SPIN_MS + SEARCH_GLANCE_MS) {
    motorBerhenti();
  } else {
    searchSwitchMs = now;
    motorKanan(SPEED_CARI);
  }
}

// ======================================================
// DEBUG
// ======================================================
void printDebugThrottled(TargetDir targetNow) {
  unsigned long now = millis();

  if (now - lastDebugMs < 250) {
    return;
  }

  lastDebugMs = now;

  Serial.print("STATE=");
  Serial.print(stateName(robotState));

  Serial.print(" | Target=");
  Serial.print(targetName(targetNow));

  Serial.print(" | Lock=");
  Serial.print(targetName(lockedTargetDir));

  Serial.print(" | Kiri=");
  Serial.print(gJarakKiri);

  Serial.print(" | Tengah=");
  Serial.print(gJarakTengah);

  Serial.print(" | Kanan=");
  Serial.print(gJarakKanan);

  Serial.print(" | AccelX=");
  Serial.print(gAccelX);

  Serial.print(" | Line=");
  Serial.print(gLineDetected);

  Serial.print(" | Code=");
  Serial.println(gLineCode);
}

// ======================================================
// RTOS TASK: IR SENSOR
// Prioritas tinggi supaya garis cepat kebaca
// ======================================================
void taskIR(void *parameter) {
  while (true) {
    uint8_t code = readLineCodeNow();

    gLineCode = code;
    gLineDetected = code != LINE_NONE;

    vTaskDelay(pdMS_TO_TICKS(IR_TASK_INTERVAL_MS));
  }
}

// ======================================================
// RTOS TASK: ULTRASONIC
// Pembacaan ultrasonic dipisah supaya pulseIn tidak menahan logika robot
// ======================================================
void taskUltrasonic(void *parameter) {
  while (true) {
    long tengah = readDistanceRaw(TRIG_TENGAH, ECHO_TENGAH);
    vTaskDelay(pdMS_TO_TICKS(6));

    long kiri = readDistanceRaw(TRIG_KIRI, ECHO_KIRI);
    vTaskDelay(pdMS_TO_TICKS(6));

    long kanan = readDistanceRaw(TRIG_KANAN, ECHO_KANAN);

    gJarakTengah = tengah;
    gJarakKiri = kiri;
    gJarakKanan = kanan;

    vTaskDelay(pdMS_TO_TICKS(ULTRA_TASK_INTERVAL_MS));
  }
}

// ======================================================
// RTOS TASK: MPU
// ======================================================
void taskMPU(void *parameter) {
  while (true) {
    if (mpuOK) {
      gAccelX = getAccelX();
    } else {
      gAccelX = 0.0;
    }

    vTaskDelay(pdMS_TO_TICKS(MPU_TASK_INTERVAL_MS));
  }
}

// ======================================================
// RTOS TASK: ROBOT STATE MACHINE
// Ini satu-satunya task utama yang mengontrol motor
// ======================================================
void taskRobot(void *parameter) {
  while (true) {
    TargetDir targetForDebug = TARGET_NONE;

    // PRIORITAS PALING TINGGI:
    // Kalau garis terdeteksi, langsung masuk state koreksi garis.
    // Ini berlaku untuk SEMUA state termasuk STATE_ANTI_STUCK -> jadi
    // walaupun robot sedang mundur/belok full PWM buat lepas dari deadlock,
    // begitu salah satu sensor IR kena garis tepi, baris ini langsung
    // memotong dan memaksa beginAvoidLine() dipanggil pada iterasi yang
    // sama, sebelum processAntiStuck() sempat jalan lagi. Robot tidak
    // akan terus mundur/belok melewati garis tepi.
    if (gLineDetected && robotState != STATE_AVOID_LINE) {
      beginAvoidLine();
    }

    if (robotState == STATE_AVOID_LINE) {
      processAvoidLine();
      printDebugThrottled(targetForDebug);
      vTaskDelay(pdMS_TO_TICKS(ROBOT_TASK_INTERVAL_MS));
      continue;
    }

    // Kalau sedang anti stuck, garis tetap bisa override karena dicek di atas.
    if (robotState == STATE_ANTI_STUCK) {
      processAntiStuck();
      printDebugThrottled(targetForDebug);
      vTaskDelay(pdMS_TO_TICKS(ROBOT_TASK_INTERVAL_MS));
      continue;
    }

    long jarakTengah = gJarakTengah;
    long jarakKiri = gJarakKiri;
    long jarakKanan = gJarakKanan;
    float accelX = gAccelX;

    TargetDir target = getDecisionTarget(jarakTengah, jarakKiri, jarakKanan);
    targetForDebug = target;

    // ======================================
    // STATE DECISION
    // ======================================
    if (target == TARGET_CLOSE) {
      setState(STATE_PUSH);

      resetTargetPID();

      // PUSH full PWM
      motorMaju(SPEED_DORONG);

      if (checkDeadlock(accelX, jarakTengah)) {
        printDebugThrottled(targetForDebug);
        vTaskDelay(pdMS_TO_TICKS(ROBOT_TASK_INTERVAL_MS));
        continue;
      }
    }

    else if (target == TARGET_FRONT) {
      setState(STATE_ATTACK);

      resetTargetPID();

      // ATTACK full PWM
      motorMaju(SPEED_SERANG);

      if (checkDeadlock(accelX, jarakTengah)) {
        printDebugThrottled(targetForDebug);
        vTaskDelay(pdMS_TO_TICKS(ROBOT_TASK_INTERVAL_MS));
        continue;
      }
    }

    else if (target == TARGET_LEFT) {
      if (robotState != STATE_TRACK_LEFT) {
        resetTargetPID();
      }

      setState(STATE_TRACK_LEFT);

      deadlockStartMs = 0;

      // PATCH TRANSISI SEARCH -> ATTACK:
      // Kalau target baru terlihat di sensor kiri, jangan maju dulu.
      // Pivot ke kiri sampai sensor tengah melihat target, lalu state akan masuk ATTACK.
      motorKiri(SPEED_LOCK_BELOK);
    }

    else if (target == TARGET_RIGHT) {
      if (robotState != STATE_TRACK_RIGHT) {
        resetTargetPID();
      }

      setState(STATE_TRACK_RIGHT);

      deadlockStartMs = 0;

      // PATCH TRANSISI SEARCH -> ATTACK:
      // Kalau target baru terlihat di sensor kanan, pivot ke kanan dulu.
      // Begitu sensor tengah melihat target, robot langsung masuk ATTACK.
      motorKanan(SPEED_LOCK_BELOK);
    }

    else {
      if (robotState != STATE_SEARCH) {
        resetTargetPID();
        searchSwitchMs = millis();
      }

      setState(STATE_SEARCH);

      deadlockStartMs = 0;

      // SEARCH agresif: putar - lirik
      doSearchMotion();
    }

    printDebugThrottled(targetForDebug);

    vTaskDelay(pdMS_TO_TICKS(ROBOT_TASK_INTERVAL_MS));
  }
}

// ======================================================
// SETUP
// ======================================================
void setup() {
  Serial.begin(115200);
  delay(1000);

  Serial.println();
  Serial.println("Robot booting RTOS + Aggressive Target Lock...");

  pinMode(IR_KIRI_DEPAN, INPUT);
  pinMode(IR_KIRI_BELAKANG, INPUT);
  pinMode(IR_KANAN_BELAKANG, INPUT);
  pinMode(IR_KANAN_DEPAN, INPUT);

  pinMode(TRIG_KIRI, OUTPUT);
  pinMode(ECHO_KIRI, INPUT);

  pinMode(TRIG_TENGAH, OUTPUT);
  pinMode(ECHO_TENGAH, INPUT);

  pinMode(TRIG_KANAN, OUTPUT);
  pinMode(ECHO_KANAN, INPUT);

  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  pinMode(ENA, OUTPUT);
  pinMode(ENB, OUTPUT);

  // PWM ESP32 untuk L298N
  ledcSetup(CH_ENA, PWM_FREQ, PWM_RES);
  ledcSetup(CH_ENB, PWM_FREQ, PWM_RES);

  ledcAttachPin(ENA, CH_ENA);
  ledcAttachPin(ENB, CH_ENB);

  motorBerhenti();

  initMPU();

  stateEnterMs = millis();
  stateStepStartMs = millis();
  searchSwitchMs = millis();
  pidLastMs = millis();

  Serial.println("Membuat RTOS task...");

  // Core 1: IR dan robot control supaya respons cepat
  xTaskCreatePinnedToCore(
    taskIR,
    "IR Task",
    2048,
    NULL,
    5,
    NULL,
    1
  );

  xTaskCreatePinnedToCore(
    taskRobot,
    "Robot State Task",
    4096,
    NULL,
    4,
    NULL,
    1
  );

  // Core 0: sensor berat / blocking
  xTaskCreatePinnedToCore(
    taskUltrasonic,
    "Ultrasonic Task",
    4096,
    NULL,
    2,
    NULL,
    0
  );

  xTaskCreatePinnedToCore(
    taskMPU,
    "MPU Task",
    3072,
    NULL,
    1,
    NULL,
    0
  );

  Serial.println("Robot Ready - Aggressive Target Lock Mode");
}

// ======================================================
// LOOP KOSONG
// Semua logic jalan di RTOS task
// ======================================================
void loop() {
  vTaskDelay(pdMS_TO_TICKS(1000));
}
