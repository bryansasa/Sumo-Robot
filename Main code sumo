// ======================================================
// MPU RAW FUNCTION
// ======================================================
byte readMPURegister(byte reg) {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(reg);
  Wire.endTransmission(false);

  Wire.requestFrom(MPU_ADDR, 1);

  if (Wire.available()) {
    return Wire.read();
  }

  return 0xFF;
}

void writeMPU(byte reg, byte value) {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(reg);
  Wire.write(value);
  Wire.endTransmission();
}

int16_t readMPU16(byte reg) {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(reg);
  Wire.endTransmission(false);

  Wire.requestFrom(MPU_ADDR, 2);

  if (Wire.available() < 2) {
    return 0;
  }

  int16_t value = Wire.read() << 8 | Wire.read();
  return value;
}

float getAccelX() {
  int16_t axRaw = readMPU16(0x3B);

  // Range accel diset +/- 8G, scale factor = 4096 LSB/g
  float ax_g = axRaw / 4096.0;

  // Konversi ke m/s^2
  float ax = ax_g * 9.81;

  return ax;
}

void initMPU() {
  Wire.begin(SDA_PIN, SCL_PIN);
  Wire.setClock(100000);
  delay(500);

  byte whoami = readMPURegister(0x75);

  Serial.print("WHO_AM_I MPU: 0x");
  Serial.println(whoami, HEX);

  if (whoami == 0x68 || whoami == 0x70 || whoami == 0x71) {
    mpuOK = true;

    // Wake up MPU
    writeMPU(0x6B, 0x00);
    delay(100);

    // Accelerometer range +/- 8G
    writeMPU(0x1C, 0x10);

    // Gyro range +/- 500 deg/s
    writeMPU(0x1B, 0x08);

    Serial.println("MPU RAW siap dibaca.");
  } else {
    mpuOK = false;
    Serial.println("MPU tidak valid, robot tetap jalan tanpa MPU.");
  }
}

// ======================================================
// MOTOR CONTROL
// ======================================================
int scalePWM(int speed, int maxKalibrasi) {
  speed = constrain(speed, 0, 255);
  maxKalibrasi = constrain(maxKalibrasi, 0, 255);

  return (speed * maxKalibrasi) / 255;
}

void setPWMKiri(int pwm) {
  pwm = constrain(pwm, 0, 255);
  ledcWrite(CH_ENA, pwm);
}

void setPWMKanan(int pwm) {
  pwm = constrain(pwm, 0, 255);
  ledcWrite(CH_ENB, pwm);
}

void motorMaju(int speed) {
  int pwmKiri = scalePWM(speed, SPEED_KIRI_MAJU);
  int pwmKanan = scalePWM(speed, SPEED_KANAN_MAJU);

  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);

  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);

  setPWMKiri(pwmKiri);
  setPWMKanan(pwmKanan);
}

void motorMundur(int speed) {
  int pwmKiri = scalePWM(speed, SPEED_KIRI_MUNDUR);
  int pwmKanan = scalePWM(speed, SPEED_KANAN_MUNDUR);

  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);

  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);

  setPWMKiri(pwmKiri);
  setPWMKanan(pwmKanan);
}

void motorKiri(int speed) {
  // Belok kiri: motor kiri mundur, motor kanan maju
  int pwmKiri = scalePWM(speed, SPEED_KIRI_MUNDUR);
  int pwmKanan = scalePWM(speed, SPEED_KANAN_MAJU);

  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);

  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);

  setPWMKiri(pwmKiri);
  setPWMKanan(pwmKanan);
}

void motorKanan(int speed) {
  // Belok kanan: motor kiri maju, motor kanan mundur
  int pwmKiri = scalePWM(speed, SPEED_KIRI_MAJU);
  int pwmKanan = scalePWM(speed, SPEED_KANAN_MUNDUR);

  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);

  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);

  setPWMKiri(pwmKiri);
  setPWMKanan(pwmKanan);
}

// Motor maju dengan speed kiri-kanan beda.
// ENA diasumsikan motor kiri, ENB diasumsikan motor kanan.
// Speed dari PID tetap dikalibrasi agar robot tidak lari ke kiri.
void motorMajuLR(int speedKiri, int speedKanan) {
  int pwmKiri = scalePWM(speedKiri, SPEED_KIRI_MAJU);
  int pwmKanan = scalePWM(speedKanan, SPEED_KANAN_MAJU);

  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);

  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);

  setPWMKiri(pwmKiri);
  setPWMKanan(pwmKanan);
}

void motorBerhenti() {
  setPWMKiri(0);
  setPWMKanan(0);

  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);

  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
}

// ======================================================
